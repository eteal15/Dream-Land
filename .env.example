# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# TELEGRAM_BOT_TOKEN: Your Telegram Bot Token from @BotFather for manual billing alerts.
TELEGRAM_BOT_TOKEN=""

# TELEGRAM_ADMIN_CHAT_ID: Telegram Chat ID of the store owner/admin to receive screenshot alerts.
TELEGRAM_ADMIN_CHAT_ID=""

# TELEBIRR MERCHANT DETAILS: Configures your real phone number and business name for Telebirr payments
VITE_TELEBIRR_NUMBER="0912345678"
VITE_TELEBIRR_NAME="ዮሴፍ የህልም መፍቻ መለያ (Joseph Dream Account)"

# ADMIN ACCESS: Add your personal Telegram User ID here so you can view/access the hidden Admin (አስተዳዳሪ) tab
VITE_ADMIN_TELEGRAM_ID="733830209"

